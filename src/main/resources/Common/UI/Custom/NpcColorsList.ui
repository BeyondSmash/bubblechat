$C = "Common.ui";

@BtnStyle = TextButtonStyle(
  Default: (LabelStyle: (FontSize: 13, TextColor: #93844c, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center), Background: (Color: #1a2533)),
  Hovered: (LabelStyle: (FontSize: 13, TextColor: #b8a960, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center), Background: (Color: #22303f)),
  Pressed: (LabelStyle: (FontSize: 13, TextColor: #ffe082, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center), Background: (Color: #152030)),
  Sounds: $C.@ButtonSounds,
);

$C.@PageOverlay {
  $C.@DecoratedContainer {
    Anchor: (Width: 520, Height: 560);

    #Title {
      Group {
        TextButton #BackButton {
          Anchor: (Left: 12, Top: 4, Width: 64, Height: 24);
          Text: "< Back";
          Style: @BtnStyle;
        }

        Label #TitleLabel {
          Anchor: (Height: 28, Horizontal: 0);
          Style: (FontSize: 20, TextColor: #93844c, RenderBold: true, HorizontalAlignment: Center);
          Text: "NPC BUBBLE COLORS";
        }

        TextButton #RefreshButton {
          Anchor: (Right: 12, Top: 4, Width: 76, Height: 24);
          Text: "Refresh";
          Style: @BtnStyle;
        }
      }
    }

    #Content {
      LayoutMode: Top;

      Label {
        Anchor: (Top: 8, Left: 14);
        Style: (FontSize: 14, TextColor: #808890);
        Text: "Nearest NPCs (within 64m)";
      }

      Group #ListContainer {
        Anchor: (Width: 500, Top: 6);
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        Padding: (Left: 7);
        ScrollbarStyle: $C.@DefaultScrollbarStyle;

        Group #ListCards {
          LayoutMode: Top;
        }
      }
    }
  }
}
